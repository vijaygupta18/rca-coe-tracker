# Copy to .env and fill in. The .env file is gitignored.

# --- Database -------------------------------------------------------------
DATABASE_URL=postgresql+asyncpg://rca:rca@localhost:5432/rca_coe
DB_SCHEMA=rca_coe

# --- Identity (Pomerium) --------------------------------------------------
# In production, the backend reads x-pomerium-claim-email / -name.
# Locally, set DEV_FAKE_EMAIL to bypass Pomerium and act as a known user.
DEV_FAKE_EMAIL=you@example.com
DEV_FAKE_NAME=Your Name

# Comma-separated. Seeded into users.is_admin on first login. After that,
# admin status lives on the DB and can be changed via the in-app Users page.
# Emails listed here cannot be demoted from the UI (recovery path).
ADMIN_EMAILS=you@example.com

# --- App URLs --------------------------------------------------------------
APP_BASE_URL=http://localhost:8000
CORS_ORIGINS=http://localhost:8000,http://localhost:5173

# --- Slack DMs (optional) --------------------------------------------------
# Leave blank to disable Slack notifications. The bot needs scopes:
#   chat:write, im:write, users:read.email
SLACK_BOT_TOKEN=
SLACK_SIGNING_SECRET=

# --- AI summary on RCA closure (optional) ----------------------------------
# Leave AI_API_KEY blank to disable AI summaries. The model used must be
# non-reasoning — reasoning models (e.g. o1-style, "thinking" models) leak
# chain-of-thought as visible text. minimax-m2 / open-fast / gpt-4o-mini work
# well; o1, claude-thinking, and similar do not.
AI_PROVIDER=openai
AI_MODEL=gpt-4o
AI_FAST_MODEL=gpt-4o-mini
AI_API_BASE=
AI_API_KEY=
AI_MAX_TOKENS=2000
AI_TEMPERATURE=0.2

# --- Build metadata --------------------------------------------------------
APP_VERSION=0.1.0
APP_COMMIT=dev
